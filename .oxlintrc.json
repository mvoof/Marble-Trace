{
  "plugins": ["typescript", "react", "jsx-a11y"],
  "options": {
    "typeAware": true
  },
  "env": {
    "browser": true,
    "es2020": true
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "src-tauri/target/**",
    "src-tauri/gen/schemas/**",
    "src/types/bindings.ts",
    "src/storybook/__mocks__/**",
    ".storybook/**"
  ],
  "overrides": [
    {
      "files": ["scripts/**/*.{js,mjs}", "vite.config.ts"],
      "env": {
        "node": true
      }
    }
  ]
}
