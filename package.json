{
  "name": "marble-trace",
  "description": "iRacing Telemetry Overlay",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "repository": {
    "url": "https://github.com/mvoof/Marble-Trace"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:release": "tauri build",
    "tauri:build:dev": "tauri build --config src-tauri/tauri.dev.conf.json --no-sign",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"./**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cargo:format": "cd src-tauri && cargo fmt"
  },
  "dependencies": {
    "@tauri-apps/api": "~2.10",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "antd": "^6.3.3",
    "i18next": "^25.6.0",
    "lucide-react": "^0.577.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.1.1",
    "react-router-dom": "^7.11.0",
    "sass": "^1.98.0",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.36.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^10.3.5",
    "playwright": "^1.59.1",
    "prettier": "^3.6.2",
    "storybook": "^10.3.5",
    "tauri-plugin-mcp-server": "^0.1.0",
    "typescript": "~5.9.2",
    "vite": "^7.1.7",
    "vitest": "^4.1.4"
  }
